{
  "appId": "com.roguecode.app",
  "productName": "roguecode",
  "directories": {
    "output": "electron-release-new"
  },
  "files": [
    {
      "from": "dist/client",
      "to": "client",
      "filter": ["**/*"]
    },
    "electron/**/*",
    "node_modules/node-pty/**/*",
    "node_modules/nan/**/*",
    "package.json"
  ],
  "asarUnpack": [
    "node_modules/node-pty/**/*",
    "node_modules/nan/**/*"
  ],
  "win": {
    "target": "portable"
  },
  "npmRebuild": false,
  "extraMetadata": {
    "main": "electron/main.cjs"
  }
}